rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // 커뮤니티 게시글 첨부파일 — 누구나 다운로드, 본인 폴더에만 업로드/삭제 가능
    // 확장자 화이트리스트 + 25MB 용량 제한으로 임의 파일 업로드를 방지
    match /community_attachments/{uid}/{fileName} {
      allow read: if true;
      allow write: if request.auth != null
        && request.auth.uid == uid
        && request.resource.size <= 26214400
        && fileName.matches('(?i).*\\.(txt|pdf|doc|docx|ppt|pptx|xls|xlsx|hwp|zip|png|jpe?g|gif|webp)$');
      allow delete: if request.auth != null && request.auth.uid == uid;
    }
  }
}

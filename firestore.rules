rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 관리자 확인 — 이메일 검증까지 요구해 다른 로그인 방식으로 이메일을 사칭하는 것을 방지
    function isAdmin() {
      return request.auth != null
        && request.auth.token.email == 'warmcomfortforyou@gmail.com'
        && request.auth.token.email_verified == true;
    }

    match /users/{userId} {
      // 본인 또는 관리자(가입자 관리 대시보드)만 읽기
      allow read: if isAdmin()
        || (request.auth != null && request.auth.uid == userId);
      allow write: if request.auth != null && request.auth.uid == userId;

      match /{document=**} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }

    // 필로소피 AI 봉사단 소식 — 누구나 읽기, 관리자만 쓰기
    match /volunteer_posts/{postId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    // 필로소피 AI 교육 사진 — 누구나 읽기, 관리자만 쓰기
    match /education_posts/{postId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    // 누적 방문자 카운터 — 누구나 읽기, 1에서 시작해 1씩 증가만 허용
    match /stats/{docId} {
      allow read: if true;
      allow create: if request.resource.data.total == 1;
      allow update: if request.resource.data.total is int
        && request.resource.data.total == resource.data.total + 1;
      allow delete: if isAdmin();
    }

    // 오늘 방문자 카운터 (날짜별 문서) — 누구나 읽기, 1에서 시작해 1씩 증가만 허용
    match /daily_visits/{dateId} {
      allow read: if true;
      allow create: if request.resource.data.count == 1;
      allow update: if request.resource.data.count is int
        && request.resource.data.count == resource.data.count + 1;
      allow delete: if isAdmin();
    }

    // AI 툴 목록 — 누구나 읽기, 관리자만 쓰기
    match /ai_tools/{toolId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    // 교육자 커뮤니티 게시판 — 누구나 읽기, 로그인 사용자 글쓰기,
    // 본인 글 또는 관리자만 삭제. 필드 형식·길이를 서버에서 강제.
    match /community_posts/{postId} {
      allow read: if true;
      allow create: if request.auth != null
        && request.resource.data.authorUid == request.auth.uid
        && request.resource.data.authorName is string
        && request.resource.data.authorName.size() >= 1
        && request.resource.data.authorName.size() <= 50
        && request.resource.data.title is string
        && request.resource.data.title.size() >= 2
        && request.resource.data.title.size() <= 120
        && request.resource.data.content is string
        && request.resource.data.content.size() >= 1
        && request.resource.data.content.size() <= 5000
        && request.resource.data.category in ['수업 사례', '바이브코딩 쇼케이스', '질문·고민', '자료 공유', '자유']
        && (!('projectUrl' in request.resource.data) || (request.resource.data.projectUrl is string && request.resource.data.projectUrl.size() <= 300))
        && (!('aiTool' in request.resource.data) || (request.resource.data.aiTool is string && request.resource.data.aiTool.size() <= 60))
        && (!('process' in request.resource.data) || (request.resource.data.process is string && request.resource.data.process.size() <= 4000));
      // 본문 수정은 불가. 좋아요/댓글 수 카운터 한 개만 ±1 변경하는 것은 허용
      allow update: if request.auth != null
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['likeCount', 'commentCount'])
        && request.resource.data.get('likeCount', 0) >= 0
        && request.resource.data.get('commentCount', 0) >= 0
        && ((request.resource.data.get('likeCount', 0) - resource.data.get('likeCount', 0))
          + (request.resource.data.get('commentCount', 0) - resource.data.get('commentCount', 0))) in [1, -1];
      allow delete: if isAdmin()
        || (request.auth != null && resource.data.authorUid == request.auth.uid);

      // 댓글 — 누구나 읽기, 로그인 사용자 작성, 본인 또는 관리자만 삭제
      match /comments/{commentId} {
        allow read: if true;
        allow create: if request.auth != null
          && request.resource.data.authorUid == request.auth.uid
          && request.resource.data.authorName is string
          && request.resource.data.authorName.size() >= 1
          && request.resource.data.authorName.size() <= 50
          && request.resource.data.content is string
          && request.resource.data.content.size() >= 1
          && request.resource.data.content.size() <= 2000;
        allow update: if false;
        allow delete: if isAdmin()
          || (request.auth != null && resource.data.authorUid == request.auth.uid);
      }

      // 좋아요 — 문서 ID = 누른 사람의 uid (1인 1개), 본인만 등록/취소
      match /likes/{likeUid} {
        allow read: if true;
        allow create: if request.auth != null && request.auth.uid == likeUid;
        allow delete: if isAdmin()
          || (request.auth != null && request.auth.uid == likeUid);
      }
    }

    // 사이트 내 알림 (내 글에 새 댓글) — 수신자 본인만 읽기/읽음 처리/삭제
    match /notifications/{noteId} {
      allow read: if request.auth != null && resource.data.toUid == request.auth.uid;
      allow create: if request.auth != null
        && request.resource.data.fromUid == request.auth.uid
        && request.resource.data.toUid is string
        && request.resource.data.toUid != request.auth.uid
        && request.resource.data.type in ['comment']
        && request.resource.data.postId is string
        && request.resource.data.postTitle is string
        && request.resource.data.postTitle.size() <= 120
        && request.resource.data.fromName is string
        && request.resource.data.fromName.size() <= 50
        && request.resource.data.read == false;
      allow update: if request.auth != null
        && resource.data.toUid == request.auth.uid
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['read']);
      allow delete: if isAdmin()
        || (request.auth != null && resource.data.toUid == request.auth.uid);
    }

    // 신고 — 로그인 사용자만 접수, 관리자만 열람/처리
    match /reports/{reportId} {
      allow read, delete: if isAdmin();
      allow create: if request.auth != null
        && request.resource.data.reporterUid == request.auth.uid
        && request.resource.data.targetType in ['post', 'comment']
        && request.resource.data.postId is string
        && request.resource.data.reason is string
        && request.resource.data.reason.size() >= 1
        && request.resource.data.reason.size() <= 500
        && request.resource.data.preview is string
        && request.resource.data.preview.size() <= 200;
      allow update: if false;
    }
  }
}
